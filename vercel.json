{
  "version": 2,
  "buildCommand": "yarn build",
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "dist/main.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": [
          "node_modules/pg/**",
          "node_modules/pg-hstore/**",
          "node_modules/sequelize/**",
          "node_modules/sequelize-typescript/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/main.js"
    }
  ]
}
